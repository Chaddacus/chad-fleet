# genui-renderer (:8107). Node service run via tsx. Build context = repo root.
# Ship with GENUI_LLM_PROVIDER=api so it needs no Claude Code (see providers/api.ts).
FROM node:22-bookworm-slim
WORKDIR /app/packages/genui-renderer

COPY packages/genui-renderer/package.json ./
RUN npm install --no-audit --no-fund
COPY packages/genui-renderer ./

ENV PORT=8107
EXPOSE 8107
CMD ["npx", "tsx", "src/server.ts"]
