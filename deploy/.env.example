# chad-fleet hub — environment contract (S6b).
# Copy to deploy/.env and fill in. docker compose reads this file.
# NEVER commit the filled-in .env (it's gitignored). Secrets here are examples only.

# --- inter-service URLs (compose service DNS; the browser only ever hits the dashboard) ---
# These default to localhost for `launch.sh` dev; in compose they point at service names.
NEXT_PUBLIC_ADMIRAL_URL=http://chad-admiral:8901
NEXT_PUBLIC_AGGREGATOR_URL=http://state-aggregator:8106
NEXT_PUBLIC_GENUI_URL=http://genui-renderer:8107
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- auth (single-operator) ---
# HUB_AUTH_SECRET: random 32+ byte secret for cookie signing (e.g. `openssl rand -hex 32`).
# HUB_AUTH_PASSWORD_HASH: scrypt hash of your password (see deploy/README). Empty = auth OFF.
HUB_AUTH_SECRET=
HUB_AUTH_PASSWORD_HASH=
HUB_AUTH_TTL_SECONDS=604800

# --- LLM backend (genui api provider + admiral) ---
# GENUI_LLM_PROVIDER=api makes the renderer run WITHOUT Claude Code installed.
GENUI_LLM_PROVIDER=api
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# --- calendar (calendar-mcp). Google service account (primary). Leave blank to skip calendar. ---
# Share your Google Calendar with the service account's client_email, then:
GOOGLE_CALENDAR_SA_JSON=
GOOGLE_CALENDAR_ID=chad3124@gmail.com
# CalDAV fallback (only used if the Google vars above are unset):
# CALENDAR_CALDAV_URL=
# CALENDAR_USER=
# CALENDAR_PASSWORD=

# --- email (email-mcp / aggregator EmailSource). Leave blank to run the hub without email. ---
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
# backend.send() uses SMTP_SSL (implicit TLS) → port 465, not the STARTTLS 587.
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
