# Captain's goose runtime — runtime state is host-local, never check in.
state/
data/

# But DO check in config (the source of truth for how captain runs goose),
# recipes (curated), and skills (curated).
!config/
!recipes/
!skills/

# permission.yaml is regenerated by goose on every run based on GOOSE_MODE
# in config.yaml — it's host-local state, not source.
config/goose/permission.yaml

